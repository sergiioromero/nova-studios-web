---
const steps = [
  {
    number: '01',
    title: 'Descubrimiento',
    description: 'Entendemos a fondo tu negocio, tu audiencia y tus objetivos. Sin esto, no hay diseño que valga.',
  },
  {
    number: '02',
    title: 'Estrategia',
    description: 'Definimos el posicionamiento, el tono de comunicación y la dirección visual antes de crear una sola pieza.',
  },
  {
    number: '03',
    title: 'Creación',
    description: 'Diseñamos con intención. Cada decisión visual tiene un porqué y está alineada con tu estrategia.',
  },
  {
    number: '04',
    title: 'Lanzamiento',
    description: 'Entregamos y acompañamos el lanzamiento para asegurarnos de que todo funciona a la perfección.',
  },
];
---

<section id="proceso" class="py-32 px-6 md:px-12">
  <div class="max-w-7xl mx-auto">

    <div class="mb-20">
      <div class="flex items-center gap-4 mb-5 reveal">
        <span class="section-line"></span>
        <span class="text-gold text-xs tracking-[0.3em] uppercase">Nuestro proceso</span>
      </div>
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
        <h2 class="font-serif font-light text-mist leading-tight reveal reveal-delay-1"
          style="font-size: clamp(36px, 5vw, 64px);">
          Cómo damos<br /><em class="text-gold-gradient not-italic">vida</em> a las ideas
        </h2>
        <p class="text-fog max-w-xs leading-relaxed text-sm reveal reveal-delay-2">
          Un proceso probado que garantiza resultados extraordinarios en cada proyecto.
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-0">
      {steps.map((step, i) => (
        <div class={`p-8 border border-gold/10 rounded-sm mb-4 md:mb-0 reveal reveal-delay-${i}`}>
          <div class="text-gold font-serif text-5xl font-light mb-6">{step.number}</div>
          <h3 class="font-serif text-xl text-mist font-light mb-3">{step.title}</h3>
          <p class="text-fog text-sm leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>

  </div>
</section>
