<section id="trabajos" class="py-32 px-6 md:px-12 bg-graphite/20">
  <div class="max-w-7xl mx-auto">

    <div class="text-center mb-20">
      <div class="flex items-center justify-center gap-4 mb-5 reveal">
        <span class="section-line"></span>
        <span class="text-gold text-xs tracking-[0.3em] uppercase">Portfolio</span>
        <span class="section-line-reverse"></span>
      </div>
      <h2 class="font-serif font-light text-mist leading-tight reveal reveal-delay-1"
        style="font-size: clamp(36px, 5vw, 64px);">
        Trabajo <em class="text-gold-gradient not-italic">selecto</em>
      </h2>
      <p class="text-fog mt-4 max-w-md mx-auto text-sm leading-relaxed reveal reveal-delay-2">
        Cada proyecto es una historia única. Aquí encontrarás una muestra de lo que somos capaces de crear.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-4">
      <!-- Large items: fixed height on md+, natural on mobile -->
