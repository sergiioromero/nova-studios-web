---
---

<section id="contacto" class="py-32 px-6 md:px-12 bg-graphite/20">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16">

      <!-- Left info -->
      <div>
        <div class="flex items-center gap-4 mb-6 reveal">
          <span class="section-line"></span>
          <span class="text-gold text-xs tracking-[0.3em] uppercase">Contacto</span>
        </div>
        <h2 class="font-serif font-light text-mist leading-tight mb-6 reveal reveal-delay-1"
          style="font-size: clamp(36px, 5vw, 64px);">
          Hablemos de<br />tu <em class="text-gold-gradient not-italic">próximo proyecto</em>
        </h2>
        <p class="text-fog leading-relaxed mb-12 reveal reveal-delay-2">
          Cuéntanos qué tienes en mente. Revisamos cada propuesta con atención y respondemos en menos de 24 horas.
        </p>

        <div class="space-y-6 reveal reveal-delay-3">
          {[
            {
              icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>`,
              label: 'Email',
              value: 'hola@novastudio.es',
              href: 'mailto:hola@novastudio.es',
            },
            {
              icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>`,
              label: 'Teléfono',
              value: '+34 910 123 456',
              href: 'tel:+34910123456',
            },
            {
              icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>`,
              label: 'Oficina',
              value: 'Calle Serrano 41, Madrid',
              href: null,
            },
          ].map(item => (
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 border border-gold/20 flex items-center justify-center flex-shrink-0">
                <svg class="w-4 h-4 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={item.icon} />
              </div>
              <div>
                <div class="text-fog text-xs tracking-widest uppercase mb-1">{item.label}</div>
                {item.href
                  ? <a href={item.href} class="text-mist hover:text-gold transition-colors">{item.value}</a>
                  : <span class="text-mist">{item.value}</span>
                }
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Form -->
      <div class="reveal reveal-delay-2">
        <form id="contact-form" class="space-y-5">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="text-fog text-xs tracking-[0.2em] uppercase block mb-2">Nombre</label>
              <input type="text" name="from_name" id="from_name" placeholder="Tu nombre" required
                class="form-input w-full px-4 py-3.5 rounded-sm text-sm" />
            </div>
            <div>
              <label class="text-fog text-xs tracking-[0.2em] uppercase block mb-2">Email</label>
              <input type="email" name="from_email" id="from_email" placeholder="tu@email.com" required
                class="form-input w-full px-4 py-3.5 rounded-sm text-sm" />
            </div>
          </div>

          <div>
            <label class="text-fog text-xs tracking-[0.2em] uppercase block mb-2">Empresa</label>
            <input type="text" name="company" id="company" placeholder="Nombre de tu empresa"
              class="form-input w-full px-4 py-3.5 rounded-sm text-sm" />
          </div>

          <div>
            <label class="text-fog text-xs tracking-[0.2em] uppercase block mb-2">Servicio de interés</label>
            <select name="service" id="service" class="form-input w-full px-4 py-3.5 rounded-sm text-sm appearance-none">
              <option value="" disabled selected>Selecciona un servicio</option>
              <option value="branding">Identidad de Marca</option>
              <option value="web">Diseño Web & UX</option>
              <option value="estrategia">Estrategia Digital</option>
              <option value="motion">Motion & Video</option>
              <option value="foto">Fotografía Editorial</option>
              <option value="integral">Paquete Integral</option>
            </select>
          </div>

          <div>
            <label class="text-fog text-xs tracking-[0.2em] uppercase block mb-2">Mensaje</label>
            <textarea name="message" id="message" rows="5" placeholder="Cuéntanos sobre tu proyecto…" required
              class="form-input w-full px-4 py-3.5 rounded-sm text-sm resize-none"></textarea>
          </div>

          <button type="submit" id="submit-btn" class="btn-gold w-full py-4 text-sm tracking-[0.15em] uppercase font-medium rounded-sm">
            <span id="btn-text">Enviar mensaje</span>
          </button>

          <p class="text-fog text-xs text-center leading-relaxed">
            Al enviar, aceptas que procesemos tus datos para responderte. Sin spam, nunca.
          </p>
        </form>
      </div>

    </div>
  </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>

<script type="module">
  import emailjs from 'https://cdn.jsdelivr.net/npm/@emailjs/browser@4/+esm';

  const EMAILJS_PUBLIC_KEY  = 'zeautLxnRwkIlHMcX';
  const EMAILJS_SERVICE_ID  = 'service_dvb7n0c';
  const EMAILJS_TEMPLATE_ID = 'template_ukw6l4j';

  emailjs.init(EMAILJS_PUBLIC_KEY);

  function showToast(message, type = 'success') {
    const toast = document.getElementById('toast');
    if (!toast) return;
    toast.textContent = message;
    toast.style.background = type === 'success'
      ? 'linear-gradient(135deg, rgba(26,26,30,0.95), rgba(200,169,110,0.15))'
      : 'linear-gradient(135deg, rgba(26,26,30,0.95), rgba(220,80,80,0.15))';
    toast.style.border = type === 'success' ? '1px solid rgba(200,169,110,0.4)' : '1px solid rgba(220,80,80,0.4)';
    toast.style.color = type === 'success' ? '#C8A96E' : '#ff6b6b';
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 4500);
  }

  const form = document.getElementById('contact-form');
  const submitBtn = document.getElementById('submit-btn');
  const btnText = document.getElementById('btn-text');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    btnText.textContent = 'Enviando…';
    submitBtn.style.opacity = '0.7';

    const templateParams = {
      from_name:  document.getElementById('from_name').value,
      from_email: document.getElementById('from_email').value,
      company:    document.getElementById('company').value,
      service:    document.getElementById('service').value,
      message:    document.getElementById('message').value,
    };

    try {
      await emailjs.send(EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_ID, templateParams);
      btnText.textContent = '✓ Enviado';
      showToast('✓ Mensaje enviado correctamente. Te contactamos en menos de 24h.');
      form.reset();
    } catch (err) {
      console.error('EmailJS error:', err);
      showToast('Error al enviar. Escríbenos directamente a hola@novastudio.es', 'error');
      btnText.textContent = 'Reintentar';
    }

    setTimeout(() => {
      submitBtn.disabled = false;
      btnText.textContent = 'Enviar mensaje';
      submitBtn.style.opacity = '1';
    }, 3000);
  });
</script>