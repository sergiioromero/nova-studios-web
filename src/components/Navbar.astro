---
const links = [
  { href: '#servicios', label: 'Servicios' },
  { href: '#trabajos', label: 'Trabajos' },
  { href: '#proceso', label: 'Proceso' },
  { href: '#sobre', label: 'Nosotros' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-[100] px-6 md:px-12 py-5 transition-all duration-400">
  <div class="max-w-7xl mx-auto flex items-center justify-between">

    <!-- Logo -->
    <a href="#" class="flex items-center gap-3 group">
      <div class="w-8 h-8 border border-gold/60 rotate-45 flex items-center justify-center group-hover:border-gold transition-colors duration-300">
        <div class="w-2 h-2 bg-gold group-hover:bg-gold-light transition-colors duration-300"></div>
      </div>
      <span class="font-serif text-xl tracking-widest text-mist">NOVA</span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-10">
      {links.map(link => (
        <a href={link.href} class="text-fog hover:text-gold text-sm tracking-widest uppercase transition-colors duration-300">
          {link.label}
        </a>
      ))}
      <a href="#contacto" class="btn-gold px-6 py-2.5 text-sm tracking-widest uppercase rounded-sm">
        Hablemos
      </a>
    </div>

    <!-- Mobile menu button -->
    <button id="menu-btn" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Abrir menú">
      <span class="w-6 h-px bg-mist transition-all duration-300 block" id="line1"></span>
      <span class="w-6 h-px bg-mist transition-all duration-300 block" id="line2"></span>
      <span class="w-4 h-px bg-gold transition-all duration-300 block" id="line3"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden absolute top-full left-0 right-0 bg-charcoal/95 backdrop-blur-xl border-t border-gold/10 px-6 py-8 hidden opacity-0 transition-opacity duration-300">
    <div class="flex flex-col gap-6">
      {links.map(link => (
        <a href={link.href} class="text-fog hover:text-gold text-sm tracking-widest uppercase transition-colors nav-link">
          {link.label}
        </a>
      ))}
      <a href="#contacto" class="btn-gold px-6 py-3 text-sm tracking-widest uppercase text-center rounded-sm mt-2 nav-link">
        Hablemos
      </a>
    </div>
  </div>
</nav>

<script>
  // Navbar scroll effect
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar?.classList.add('bg-obsidian/85', 'backdrop-blur-xl', 'border-b', 'border-gold/10');
    } else {
      navbar?.classList.remove('bg-obsidian/85', 'backdrop-blur-xl', 'border-b', 'border-gold/10');
    }
  });

  // Mobile menu toggle
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  let open = false;

  menuBtn?.addEventListener('click', () => {
    open = !open;
    if (open) {
      mobileMenu?.classList.remove('hidden');
      setTimeout(() => mobileMenu?.classList.replace('opacity-0', 'opacity-100'), 10);
    } else {
      mobileMenu?.classList.replace('opacity-100', 'opacity-0');
      setTimeout(() => mobileMenu?.classList.add('hidden'), 300);
    }
  });

  // Close on link click
  document.querySelectorAll('.nav-link').forEach(link => {
    link.addEventListener('click', () => {
      open = false;
      mobileMenu?.classList.replace('opacity-100', 'opacity-0');
      setTimeout(() => mobileMenu?.classList.add('hidden'), 300);
    });
  });
</script>
